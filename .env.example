OPENAI_API_KEY=""
HF_API=""
GEMINI_API_KEY=""
# OpenAI 429 시 vLLM(Qwen2.5-7B 등) 폴백. true + vllm 설치 시 429 발생하면 vLLM으로 재시도. 자세한 내용: etc_md/OPENAI_RATE_LIMIT_VLLM_FALLBACK.md
# ENABLE_VLLM_FALLBACK_ON_RATE_LIMIT=false
# vLLM 사용 시(429 폴백·기동 시 1차) RunPod Serverless GPU 사용. true면 요청 시 GPU 기동·유휴 시 스케일다운(비용 절감). 대상: RunPod. RUNPOD_API_KEY 필요.
# VLLM_USE_RUNPOD_GPU=false
# RunPod vLLM 전용 엔드포인트 ID. 미설정 시 RUNPOD_ENDPOINT_ID 사용.
# RUNPOD_VLLM_ENDPOINT_ID=
# RunPod API (Serverless 엔드포인트 호출·429 폴백 RunPod GPU 시 필요)
# RUNPOD_API_KEY=
# RUNPOD_ENDPOINT_ID=g09uegksn7h7ed
# Prefect Pod 생성 시 Docker 이미지 (용도별). 미설정 시 아래 기본값 사용.
# RUNPOD_POD_IMAGE_NAME_LABELING=jinsoo1218/runpod-pod-vllm:latest
# RUNPOD_POD_IMAGE_NAME_TRAIN=jinsoo1218/train-llm:latest
# RunPod Network Volume S3 API (라벨/학습 결과 업로드). 라벨링 후 네트워크 볼륨에 업로드 시 사용.
# RUNPOD_S3_ACCESS_KEY=         # RunPod 콘솔 S3 API Key (user_...)
# RUNPOD_S3_SECRET_ACCESS_KEY=   # RunPod S3 API Secret (rps_...)
# RUNPOD_NETWORK_VOLUME_ID=4rlm64f9lv   # 업로드 대상 볼륨 ID (기본: train용 4rlm64f9lv)

# Redis (캐시·분산 락·RQ 큐). docker-compose 시 REDIS_HOST=redis 로 설정됨
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# 배치 큐 (BATCH_USE_QUEUE=true 시 API가 enqueue, RQ worker가 소비). offline_batch_strategy.md 참고
# BATCH_USE_QUEUE=false
# RQ_QUEUE_NAME=batch
# BATCH_JOB_MAX_RETRIES=3

# 결과 버전 관리 (A/B 비교·재실행 안전). restaurant_id+analysis_type+model_version+prompt_version+created_at
# PROMPT_VERSION=v1

# Qdrant 설정
# ":memory:" - 메모리 모드 (테스트용, 재시작 시 데이터 삭제)
# "./qdrant_db" - on-disk 모드 (로컬 디스크에 저장, 기본값)
# "http://localhost:6333" - 원격 Qdrant 서버
QDRANT_URL="./qdrant_db"
# 벡터 스토리지: false=RAM(in-memory, 기본, 최고 속도), true=MMAP(디스크, RAM 절감). 자세한 비교: etc_md/qdrant_on_disk_comparison.md
# QDRANT_VECTORS_ON_DISK=false



# 배치 요약: search_async=aspect 3개 병렬, restaurant_async=음식점 간 병렬
# Summary 배치: aspect 서치 병렬, 음식점 간 병렬
# SUMMARY_SEARCH_ASYNC=false
# SUMMARY_RESTAURANT_ASYNC=false
# BATCH_SEARCH_CONCURRENCY=50
# BATCH_LLM_CONCURRENCY=8
# LLM 비동기(llm_async): true면 배치에서 httpx.AsyncClient/AsyncOpenAI 사용
# Summary 배치: LLM 호출. true=AsyncOpenAI, false=to_thread
# SUMMARY_LLM_ASYNC=false
# Comparison LLM: true면 service/price 병렬 호출, false면 순차(기본값 동기)
# COMPARISON_ASYNC=false
# Comparison 배치: true면 음식점 간 병렬(asyncio.gather), false면 순차(기본값)
# COMPARISON_BATCH_ASYNC=false

# Sentiment: 분류기 블로킹 격리(to_thread). true면 HF 분류기를 스레드에서 실행(이벤트 루프 블로킹 방지). 기본값 false
# SENTIMENT_CLASSIFIER_USE_THREAD=false
# Sentiment: LLM 재판정 비동기. true면 AsyncOpenAI, false면 동기(기본값)
# SENTIMENT_LLM_ASYNC=false

# 메트릭/로그 수집: false면 수집 안 함(기본), true면 아래 로그/DB 설정 적용
# METRICS_AND_LOGGING_ENABLE=false
# METRICS_ENABLE_LOGGING=true
# METRICS_ENABLE_DB=true
# METRICS_DB_PATH=metrics.db
# METRICS_LOG_DIR=logs

# CPU 실시간 모니터링: true면 백그라운드에서 주기적 샘플링 → logs/cpu_usage.log
# CPU_MONITOR_ENABLE=false
# CPU_MONITOR_INTERVAL=1.0

# Docker 이미지 이름 (docker-compose + Docker Hub 푸시)
# 미설정 시 api 이미지: local/tasteam_pipeline:latest 로 빌드·태그
# DOCKERHUB_USER=your-dockerhub-username
# IMAGE_TAG=1.0.0

# Docker Hub 빌드/푸시 (scripts/build_and_push.sh 사용 시)
# DOCKERHUB_USERNAME=your-dockerhub-username
# DOCKER_IMAGE_NAME=tasteam-review-api