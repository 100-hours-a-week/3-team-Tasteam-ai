# Qdrant 설정
# ":memory:" - 메모리 모드 (테스트용, 재시작 시 데이터 삭제)
# "./qdrant_db" - on-disk 모드 (로컬 디스크에 저장, 기본값)
# "http://localhost:6333" - 원격 Qdrant 서버
OPENAI_API_KEY=""
GEMINI_API_KEY=""
WANDB_API_KEY=""
# wandb 로컬 어댑터 자동 다운로드 시 (선택) entity/project
WANDB_ENTITY=""
WANDB_PROJECT="tasteam-distill"
# USE_DISTILL_SUMMARY=true 일 때: 로컬 adapter 경로 (없으면 WANDB 로 받음)
# DISTILL_ADAPTER_PATH=artifacts/<run_id>/adapter
# 정확한 artifact 이름: DISTILL_ADAPTER_ARTIFACT=entity/project/qlora-adapter-<run_id>:latest
DISTILL_ADAPTER_ARTIFACT=""
RUNPOD_API_KEY=""
LLM_PROVIDER=openai
QDRANT_VECTORS_ON_DISK=true
QDRANT_URL="/qdrant_data"
HF_HOME=/app/models
EMBEDDING_CACHE_DIR=/app/models

# Retrieval 서비스 분리 (점진 전환 토글)
USE_RETRIEVAL_SERVICE=false
RETRIEVAL_SERVICE_URL="http://localhost:8010"