# RunPod Serverless vLLM 워커 이미지 (네트워크 볼륨에서 모델 로드, 없으면 최초 1회 다운로드)
# RunPod 콘솔에서 이 이미지로 엔드포인트 배포 시 사용.
# - 볼륨에 모델이 이미 있으면 → 그대로 vLLM 기동
# - 없으면 → snapshot_download로 해당 경로에 다운로드 후 vLLM 기동
#
# 빌드: docker build -f Dockerfile.runpod-serverless-vllm -t your-registry/tasteam-runpod-vllm:latest .
# 푸시 후 RunPod Serverless 엔드포인트 생성 시 이 이미지 선택 + 네트워크 볼륨 연결.
#
# 상세: how_runpod_serverless_network_volume.md 참고
# worker-vllm: https://github.com/runpod-workers/worker-vllm/releases (태그 목록)
# Docker Hub에 'latest' 없음 → 버전 태그 사용. 다른 태그: --build-arg WORKER_VLLM_TAG=v2.11.3
ARG WORKER_VLLM_TAG=v2.5.0dev-cuda12.1.0
FROM runpod/worker-v1-vllm:${WORKER_VLLM_TAG}

# 네트워크 볼륨 마운트 경로. 모델이 없으면 HF_MODEL_ID 기준으로 여기 경로에 다운로드함.
ENV MODEL_NAME=/runpod-volume/llm-models/Qwen/Qwen2.5-7B-Instruct
ENV HF_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
ENV MAX_MODEL_LEN=4096
ENV TENSOR_PARALLEL_SIZE=1
ENV GPU_MEMORY_UTILIZATION=0.95

# 최초 1회 다운로드 + vLLM 기동용 엔트리포인트 (snapshot_download 사용)
COPY scripts/runpod_serverless_entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["python3", "/src/handler.py"]
